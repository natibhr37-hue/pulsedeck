{
  "name": "pulsedeck",
  "version": "1.0.2",
  "description": "PulseDeck — DJ software with big display, AI track matching, effects, MIDI and multi-language tutorial",
  "main": "electron-main.js",
  "author": "PulseDeck",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win",
    "dist-portable": "electron-builder --win portable"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.pulsedeck.dj",
    "productName": "PulseDeck",
    "asarUnpack": [
      "audio/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "natibhr37-hue",
        "repo": "pulsedeck"
      }
    ],
    "files": [
      "index.html",
      "style.css",
      "app.js",
      "midi.js",
      "tutorial.js",
      "electron-main.js",
      "icon.png",
      "audio/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "PulseDeck"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
